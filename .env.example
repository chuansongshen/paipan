NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# 开发/测试阶段默认直连 AI Studio API；生产部署改为 vertex。
GENAI_BACKEND=studio
GEMINI_API_KEY=
GEMINI_REPORT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FOLLOW_UP_MODEL=gemini-3.1-flash-lite-preview

# 生产切换 Vertex AI 时填写以下配置。
VERTEX_PROJECT_ID=
VERTEX_LOCATION=asia-east2
VERTEX_API_VERSION=v1

# 本地联调可不填 DATABASE_URL，服务会退化为内存仓储。
DATABASE_URL=

# 微信支付配置留待生产接入。
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_NOTIFY_URL=
