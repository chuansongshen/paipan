NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# 当前支持两种 Gemini 后端：
# 1. studio：使用 Gemini Developer API / AI Studio key
# 2. vertex：使用 Vertex AI
# 如果不显式配置，代码会在 development 默认走 studio，在 production 默认走 vertex。
GENAI_BACKEND=studio
PAYMENT_BACKEND=mock
GEMINI_API_KEY=
GEMINI_REPORT_MODEL=gemini-3.1-flash-lite-preview
GEMINI_FOLLOW_UP_MODEL=gemini-3.1-flash-lite-preview

# 选择 studio 时必须填写 GEMINI_API_KEY。
# 选择 vertex 时必须填写以下配置。
VERTEX_PROJECT_ID=
VERTEX_LOCATION=asia-east2
VERTEX_API_VERSION=v1

# 本地联调可不填 DATABASE_URL，服务会退化为内存仓储。
DATABASE_URL=
SESSION_COOKIE_NAME=pai_pan_sid
SESSION_COOKIE_SECRET=
SESSION_COOKIE_SECURE=false

# 微信身份与支付配置留待生产接入。
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_MCH_ID=
WECHAT_NOTIFY_URL=
WECHAT_OAUTH_REDIRECT_URI=
WECHAT_OAUTH_SCOPE=snsapi_base
WECHAT_API_V3_KEY=
WECHAT_MCH_SERIAL_NO=
WECHAT_PRIVATE_KEY=
